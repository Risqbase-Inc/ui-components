      "collector": {
        "healthy":  { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Telemetry collector — healthy state",  "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/collector/healthy", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } },
        "degraded": { "$value": "{color.palette.amber.500}",   "$type": "color", "$description": "Telemetry collector — degraded state", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/collector/degraded", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } },
        "failed":   { "$value": "{color.palette.red.500}",     "$type": "color", "$description": "Telemetry collector — failed state",   "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/collector/failed", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } },
        "disabled": { "$value": "{color.neutral.stone.400}",   "$type": "color", "$description": "Telemetry collector — disabled state", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/collector/disabled", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } }
      },
      "opt-out-marker": { "$value": "{color.palette.sky.500}",    "$type": "color", "$description": "Telemetry opt-out marker on surfaces", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/opt-out-marker", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } },
      "sampled-marker": { "$value": "{color.palette.violet.500}", "$type": "color", "$description": "Telemetry sampled-event marker",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/telemetry/sampled-marker", "scopes": ["SHAPE_FILL", "STROKE_COLOR"] } } },
