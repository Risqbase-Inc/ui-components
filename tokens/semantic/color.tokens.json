    "iris": {
      "$comment": "Iris semantic namespace added in v4.3 (§4.2). Nine tokens that resolve through the teal palette but are named explicitly so RALIA / Cortex / future products can re-bind the Iris character per product without touching primitives. Layer-2 generic primitives consume `iris.*`; the *character* Iris is RALIA-private (Layer 3).",
      "accent":          { "$value": "{color.palette.teal.600}", "$type": "color", "$description": "Iris accent — primary teal signature (lettermark, focus halo, prompt-chip)", "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.contrastLevel": "aa-large", "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/accent", "scopes": ["ALL_FILLS", "SHAPE_FILL", "STROKE_COLOR", "TEXT_FILL"] } } },
      "accent-hover":    { "$value": "{color.palette.teal.700}", "$type": "color", "$description": "Iris accent hover state",                                                  "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.contrastLevel": "aa-large", "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/accent-hover", "scopes": ["ALL_FILLS", "SHAPE_FILL", "STROKE_COLOR", "TEXT_FILL"] } } },
      "accent-subtle":   { "$value": "{color.palette.teal.100}", "$type": "color", "$description": "Iris accent subtle background — focus halo, prompt-chip hover",         "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/accent-subtle", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "accent-on":       { "$value": "{color.neutral.white}",     "$type": "color", "$description": "Text / icon colour on Iris accent surface — AA Large (≥18.66px bold or ≥24px regular) or Non-Text (3:1) uses only. For body text on `iris.accent`, use `iris.accent-on-dark`. v4.3 §4.2 contrast contract.", "$extensions": { "com.risqbase.themeInvariant": "White glyph contract is size-gated (v4.3 §4.2); the dark iris.accent value keeps ≥3:1 under white, so the glyph stays white in both themes", "com.risqbase.contrastLevel": "aa-large", "com.risqbase.role": "semantic", "com.risqbase.contrastPair": "{color.iris.accent}", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/accent-on", "scopes": ["TEXT_FILL"] } } },
      "accent-on-dark":  { "$value": "{color.neutral.stone.900}", "$type": "color", "$description": "Dark-glyph text / icon on Iris accent surface — use at any body size (AA Normal). v4.3 §4.2 contrast contract.",                                                                                                  "$extensions": { "com.risqbase.themeInvariant": "Stone-900 glyph clears ≥4.5:1 on both the light and dark iris.accent values", "com.risqbase.role": "semantic", "com.risqbase.contrastPair": "{color.iris.accent}", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/accent-on-dark", "scopes": ["TEXT_FILL"] } } },
      "surface":         { "$value": "{color.palette.teal.50}",   "$type": "color", "$description": "Iris surface — panel background, conversation strip",                   "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/surface", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
      "streamhead":      { "$value": "{color.palette.teal.600}",  "$type": "color", "$description": "StreamingText cursor / streamhead colour",                              "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.contrastLevel": "aa-large", "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/streamhead", "scopes": ["TEXT_FILL", "SHAPE_FILL"] } } },
      "thinking-outer":  { "$value": "{color.palette.teal.300}",  "$type": "color", "$description": "IrisThinking outer arc",                                                "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/thinking-outer", "scopes": ["STROKE_COLOR"] } } },
      "thinking-mid":    { "$value": "{color.palette.teal.500}",  "$type": "color", "$description": "IrisThinking middle arc",                                               "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/thinking-mid", "scopes": ["STROKE_COLOR"] } } },
      "thinking-inner":  { "$value": "{color.palette.teal.700}",  "$type": "color", "$description": "IrisThinking inner arc",                                               "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/iris/thinking-inner", "scopes": ["STROKE_COLOR"] } } }
