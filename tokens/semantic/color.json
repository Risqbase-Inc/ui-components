{
  "color": {
    "action": {
      "primary": {
        "$value": "{color.brand.indigo.600}",
        "$type": "color",
        "$description": "Primary action surface — CTAs, primary buttons",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.contrastPair": "{color.surface.default}",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/action/primary", "scopes": ["ALL_FILLS", "SHAPE_FILL", "STROKE_COLOR", "TEXT_FILL"] }
        }
      },
      "primary-hover": {
        "$value": "{color.brand.indigo.700}",
        "$type": "color",
        "$description": "Primary action hover state",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/action/primary-hover", "scopes": ["ALL_FILLS", "SHAPE_FILL", "STROKE_COLOR", "TEXT_FILL"] }
        }
      },
      "primary-subtle": {
        "$value": "{color.brand.indigo.100}",
        "$type": "color",
        "$description": "Primary action subtle background — hover for ghost/secondary",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/action/primary-subtle", "scopes": ["ALL_FILLS", "SHAPE_FILL"] }
        }
      }
    },
    "surface": {
      "default": {
        "$value": "{color.neutral.white}",
        "$type": "color",
        "$description": "Default surface background",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/surface/default", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
        }
      },
      "subtle": {
        "$value": "{color.neutral.stone.50}",
        "$type": "color",
        "$description": "Subtle background — coming-soon badge, panels",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/surface/subtle", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
        }
      },
      "muted": {
        "$value": "{color.neutral.stone.100}",
        "$type": "color",
        "$description": "Muted background — neutral chips, subtle badges",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/surface/muted", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
        }
      },
      "inverse": {
        "$value": "{color.neutral.stone.900}",
        "$type": "color",
        "$description": "Inverse surface — dark footer, modal scrims",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/surface/inverse", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
        }
      }
    },
    "text": {
      "default": {
        "$value": "{color.neutral.stone.800}",
        "$type": "color",
        "$description": "Default body text",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.contrastPair": "{color.surface.default}",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/text/default", "scopes": ["TEXT_FILL"] }
        }
      },
      "subtle": {
        "$value": "{color.neutral.stone.500}",
        "$type": "color",
        "$description": "Subtle / secondary text",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/text/subtle", "scopes": ["TEXT_FILL"] }
        }
      },
      "on-action": {
        "$value": "{color.neutral.white}",
        "$type": "color",
        "$description": "Text on primary action surface",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.contrastPair": "{color.action.primary}",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/text/on-action", "scopes": ["TEXT_FILL"] }
        }
      },
      "on-inverse": {
        "$value": "{color.neutral.white}",
        "$type": "color",
        "$description": "Text on inverse surface — footer headings, primary on dark",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.contrastPair": "{color.surface.inverse}",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/text/on-inverse", "scopes": ["TEXT_FILL"] }
        }
      },
      "on-inverse-subtle": {
        "$value": "{color.neutral.stone.400}",
        "$type": "color",
        "$description": "Subtle text on inverse surface — footer body, copyright",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.contrastPair": "{color.surface.inverse}",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/text/on-inverse-subtle", "scopes": ["TEXT_FILL"] }
        }
      }
    },
    "border": {
      "default": {
        "$value": "{color.neutral.stone.200}",
        "$type": "color",
        "$description": "Default border / divider",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/border/default", "scopes": ["STROKE_COLOR"] }
        }
      },
      "subtle": {
        "$value": "{color.neutral.stone.100}",
        "$type": "color",
        "$description": "Subtle border — header bottom rule",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/border/subtle", "scopes": ["STROKE_COLOR"] }
        }
      },
      "inverse": {
        "$value": "{color.neutral.stone.700}",
        "$type": "color",
        "$description": "Border on inverse surface — footer bottom-bar divider",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/border/inverse", "scopes": ["STROKE_COLOR"] }
        }
      },
      "focus": {
        "$value": "{color.brand.indigo.500}",
        "$type": "color",
        "$description": "Focus ring colour",
        "$extensions": {
          "com.risqbase.role": "semantic",
          "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/border/focus", "scopes": ["STROKE_COLOR"] }
        }
      }
    },
    "risk": {
      "low":      { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Risk band — low",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/risk/low", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "medium":   { "$value": "{color.palette.amber.500}",   "$type": "color", "$description": "Risk band — medium",   "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/risk/medium", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "high":     { "$value": "{color.palette.orange.500}",  "$type": "color", "$description": "Risk band — high",     "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/risk/high", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "critical": { "$value": "{color.palette.red.600}",     "$type": "color", "$description": "Risk band — critical", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/risk/critical", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } }
    },
    "chart": {
      "cat": {
        "1": { "$value": "{color.brand.indigo.600}",   "$type": "color", "$description": "Chart categorical 1", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/1", "scopes": ["SHAPE_FILL"] } } },
        "2": { "$value": "{color.palette.teal.600}",    "$type": "color", "$description": "Chart categorical 2", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/2", "scopes": ["SHAPE_FILL"] } } },
        "3": { "$value": "{color.palette.amber.500}",   "$type": "color", "$description": "Chart categorical 3", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/3", "scopes": ["SHAPE_FILL"] } } },
        "4": { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Chart categorical 4", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/4", "scopes": ["SHAPE_FILL"] } } },
        "5": { "$value": "{color.palette.violet.500}",  "$type": "color", "$description": "Chart categorical 5", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/5", "scopes": ["SHAPE_FILL"] } } },
        "6": { "$value": "{color.palette.rose.500}",    "$type": "color", "$description": "Chart categorical 6", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/6", "scopes": ["SHAPE_FILL"] } } },
        "7": { "$value": "{color.palette.sky.500}",     "$type": "color", "$description": "Chart categorical 7", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/7", "scopes": ["SHAPE_FILL"] } } },
        "8": { "$value": "{color.palette.lime.500}",    "$type": "color", "$description": "Chart categorical 8", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/cat/8", "scopes": ["SHAPE_FILL"] } } }
      },
      "seq": {
        "1": { "$value": "{color.palette.teal.100}", "$type": "color", "$description": "Chart sequential 1 (lightest)", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/seq/1", "scopes": ["SHAPE_FILL"] } } },
        "2": { "$value": "{color.palette.teal.300}", "$type": "color", "$description": "Chart sequential 2",            "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/seq/2", "scopes": ["SHAPE_FILL"] } } },
        "3": { "$value": "{color.palette.teal.500}", "$type": "color", "$description": "Chart sequential 3",            "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/seq/3", "scopes": ["SHAPE_FILL"] } } },
        "4": { "$value": "{color.palette.teal.700}", "$type": "color", "$description": "Chart sequential 4",            "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/seq/4", "scopes": ["SHAPE_FILL"] } } },
        "5": { "$value": "{color.palette.teal.900}", "$type": "color", "$description": "Chart sequential 5 (darkest)",  "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/seq/5", "scopes": ["SHAPE_FILL"] } } }
      },
      "div": {
        "n2": { "$value": "{color.palette.red.700}",   "$type": "color", "$description": "Diverging strong negative", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/div/n2", "scopes": ["SHAPE_FILL"] } } },
        "n1": { "$value": "{color.palette.red.500}",   "$type": "color", "$description": "Diverging negative",        "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/div/n1", "scopes": ["SHAPE_FILL"] } } },
        "0":  { "$value": "{color.neutral.stone.300}", "$type": "color", "$description": "Diverging neutral",         "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/div/0", "scopes": ["SHAPE_FILL"] } } },
        "p1": { "$value": "{color.palette.teal.500}",  "$type": "color", "$description": "Diverging positive",        "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/div/p1", "scopes": ["SHAPE_FILL"] } } },
        "p2": { "$value": "{color.palette.teal.700}",  "$type": "color", "$description": "Diverging strong positive", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/div/p2", "scopes": ["SHAPE_FILL"] } } }
      },
      "axis":            { "$value": "{color.neutral.stone.200}", "$type": "color", "$description": "Chart axis line",       "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/axis", "scopes": ["STROKE_COLOR"] } } },
      "gridline":        { "$value": "{color.neutral.stone.100}", "$type": "color", "$description": "Chart gridline",        "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/gridline", "scopes": ["STROKE_COLOR"] } } },
      "tooltip-surface": { "$value": "{color.neutral.white}",     "$type": "color", "$description": "Chart tooltip surface", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/tooltip-surface", "scopes": ["SHAPE_FILL"] } } },
      "tooltip-border":  { "$value": "{color.neutral.stone.200}", "$type": "color", "$description": "Chart tooltip border",  "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/tooltip-border", "scopes": ["STROKE_COLOR"] } } },
      "null":            { "$value": "{color.neutral.stone.300}", "$type": "color", "$description": "Null-marker hatched fill", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/chart/null", "scopes": ["SHAPE_FILL"] } } }
    },
    "gauge": {
      "track":      { "$value": "{color.neutral.stone.200}", "$type": "color", "$description": "Gauge track (background arc)", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/gauge/track", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-teal":   { "$value": "{color.palette.teal.600}",  "$type": "color", "$description": "Gauge arc — teal default",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/gauge/arc-teal", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-indigo": { "$value": "{color.brand.indigo.600}",   "$type": "color", "$description": "Gauge arc — indigo",            "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/gauge/arc-indigo", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-stone":  { "$value": "{color.neutral.stone.500}",  "$type": "color", "$description": "Gauge arc — stone (dual-ring)", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/gauge/arc-stone", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } }
    },
    "citation": {
      "surface-default":  { "$value": "{color.neutral.white}",     "$type": "color", "$description": "Citation chip surface — default",        "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/surface-default", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "surface-low-conf": { "$value": "{color.neutral.stone.50}",  "$type": "color", "$description": "Citation chip surface — low-confidence", "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/surface-low-conf", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "border-default":   { "$value": "{color.neutral.stone.200}", "$type": "color", "$description": "Citation chip border — default",          "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/border-default", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "border-retracted": { "$value": "{color.neutral.stone.300}", "$type": "color", "$description": "Citation chip border — retracted",        "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/border-retracted", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "text-default":     { "$value": "{color.neutral.stone.600}", "$type": "color", "$description": "Citation chip text — default",            "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/text-default", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "text-retracted":   { "$value": "{color.neutral.stone.400}", "$type": "color", "$description": "Citation chip text — retracted",          "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/text-retracted", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "icon-default":     { "$value": "{color.neutral.stone.500}", "$type": "color", "$description": "Citation chip source-type glyph fill",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/icon-default", "scopes": ["TEXT_FILL", "SHAPE_FILL"] } } },
      "hover":            { "$value": "{color.neutral.stone.100}", "$type": "color", "$description": "Citation chip hover state overlay",       "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/hover", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "active":           { "$value": "{color.neutral.stone.200}", "$type": "color", "$description": "Citation chip active/pressed overlay",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/citation/active", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } }
    },
    "band": {
      "$comment": "Five-band status / risk-band semantics added in v4.2.1 patch T1 (§15.6.7). 5 bands × 4 properties = 20 tokens. Harmonised across charts, gauges, dashboards. Reference: GOV.UK 5-band semantic scale.",
      "very-low": {
        "bg":     { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Very-low band background",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/very-low/bg", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border": { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Very-low band border",          "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/very-low/border", "scopes": ["STROKE_COLOR"] } } },
        "text":   { "$value": "{color.neutral.white}",       "$type": "color", "$description": "Very-low band text on-band",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/very-low/text", "scopes": ["TEXT_FILL"] } } },
        "icon":   { "$value": "{color.neutral.white}",       "$type": "color", "$description": "Very-low band icon on-band",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/very-low/icon", "scopes": ["TEXT_FILL", "SHAPE_FILL"] } } }
      },
      "low": {
        "bg":     { "$value": "{color.palette.lime.500}",  "$type": "color", "$description": "Low band background",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/low/bg", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border": { "$value": "{color.palette.lime.500}",  "$type": "color", "$description": "Low band border",          "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/low/border", "scopes": ["STROKE_COLOR"] } } },
        "text":   { "$value": "{color.neutral.stone.900}", "$type": "color", "$description": "Low band text on-band",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/low/text", "scopes": ["TEXT_FILL"] } } },
        "icon":   { "$value": "{color.neutral.stone.900}", "$type": "color", "$description": "Low band icon on-band",    "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/low/icon", "scopes": ["TEXT_FILL", "SHAPE_FILL"] } } }
      },
      "medium": {
        "bg":     { "$value": "{color.palette.amber.500}", "$type": "color", "$description": "Medium band background",      "$extensions": { "com.risqbase.role": "semantic", "com.risqbase.figma": { "collection": "semantic", "mode": "light", "variable": "color/band/medium/bg", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
