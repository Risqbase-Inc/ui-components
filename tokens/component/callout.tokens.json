{
  "color": {
    "callout": {
      "$comment": "Callout intent → role-token mapping (v4.3 §4.3). Five intents, each with background / border / icon / text. Replaces the AI-slop left-border-accent pattern (closes RALIA F-002, marketing C-05).",
      "info": {
        "background": { "$value": "{color.palette.sky.500}",    "$type": "color", "$description": "Info callout background ramp (alpha-blended in component)", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/info/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border":     { "$value": "{color.palette.sky.500}",    "$type": "color", "$description": "Info callout border",                                       "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/info/border", "scopes": ["STROKE_COLOR"] } } },
        "icon":       { "$value": "{color.palette.sky.500}",    "$type": "color", "$description": "Info callout icon",                                         "$extensions": { "com.risqbase.contrastExempt": "decorative reinforcement: the icon span is aria-hidden in-component; intent is carried by title/body text and the border (WCAG 1.4.11 decorative exemption)", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/info/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
        "text":       { "$value": "{color.text.default}",       "$type": "color", "$description": "Info callout body text",                                    "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/info/text", "scopes": ["TEXT_FILL"] } } }
      },
      "warning": {
        "background": { "$value": "{color.palette.amber.500}",  "$type": "color", "$description": "Warning callout background ramp", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/warning/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border":     { "$value": "{color.palette.amber.500}",  "$type": "color", "$description": "Warning callout border",          "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/warning/border", "scopes": ["STROKE_COLOR"] } } },
        "icon":       { "$value": "{color.palette.amber.500}",  "$type": "color", "$description": "Warning callout icon",            "$extensions": { "com.risqbase.contrastExempt": "decorative reinforcement: the icon span is aria-hidden in-component; intent is carried by title/body text and the border (WCAG 1.4.11 decorative exemption)", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/warning/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
        "text":       { "$value": "{color.text.default}",       "$type": "color", "$description": "Warning callout body text",       "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/warning/text", "scopes": ["TEXT_FILL"] } } }
      },
      "danger": {
        "background": { "$value": "{color.palette.red.600}",   "$type": "color", "$description": "Danger callout background ramp", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/danger/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border":     { "$value": "{color.palette.red.600}",   "$type": "color", "$description": "Danger callout border",          "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/danger/border", "scopes": ["STROKE_COLOR"] } } },
        "icon":       { "$value": "{color.palette.red.600}",   "$type": "color", "$description": "Danger callout icon",            "$extensions": { "com.risqbase.contrastExempt": "decorative reinforcement: the icon span is aria-hidden in-component; intent is carried by title/body text and the border (WCAG 1.4.11 decorative exemption)", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/danger/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
        "text":       { "$value": "{color.text.default}",      "$type": "color", "$description": "Danger callout body text",       "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/danger/text", "scopes": ["TEXT_FILL"] } } }
      },
      "success": {
        "background": { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Success callout background ramp", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/success/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border":     { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Success callout border",          "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/success/border", "scopes": ["STROKE_COLOR"] } } },
        "icon":       { "$value": "{color.palette.emerald.500}", "$type": "color", "$description": "Success callout icon",            "$extensions": { "com.risqbase.contrastExempt": "decorative reinforcement: the icon span is aria-hidden in-component; intent is carried by title/body text and the border (WCAG 1.4.11 decorative exemption)", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/success/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
        "text":       { "$value": "{color.text.default}",        "$type": "color", "$description": "Success callout body text",       "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/success/text", "scopes": ["TEXT_FILL"] } } }
      },
      "tip": {
        "background": { "$value": "{color.iris.accent}",         "$type": "color", "$description": "Tip callout background ramp (Iris teal)", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/tip/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
        "border":     { "$value": "{color.iris.accent}",         "$type": "color", "$description": "Tip callout border",                     "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/tip/border", "scopes": ["STROKE_COLOR"] } } },
        "icon":       { "$value": "{color.iris.accent}",         "$type": "color", "$description": "Tip callout icon",                       "$extensions": { "com.risqbase.contrastExempt": "decorative reinforcement: the icon span is aria-hidden in-component; intent is carried by title/body text and the border (WCAG 1.4.11 decorative exemption)", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/tip/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
        "text":       { "$value": "{color.text.default}",        "$type": "color", "$description": "Tip callout body text",                  "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/callout/tip/text", "scopes": ["TEXT_FILL"] } } }
      }
    }
  }
}
