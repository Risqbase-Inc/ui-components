{
  "color": {
    "footer": {
      "background": {
        "$value": "{color.surface.inverse}",
        "$type": "color",
        "$description": "Footer background — inverse surface",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/background", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
        }
      },
      "heading": {
        "$value": "{color.text.on-inverse}",
        "$type": "color",
        "$description": "Footer column heading text colour",
        "$extensions": { "com.risqbase.contrastPair": "{color.footer.background}",
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/heading", "scopes": ["TEXT_FILL"] }
        }
      },
      "link": {
        "default": {
          "$value": "{color.neutral.stone.300}",
          "$type": "color",
          "$description": "Footer link — default state. AAA bump (brand-mark v3 PR-A): on-inverse-subtle (stone-400, ≈6.9:1 on stone-900) missed 7:1 by a hair → stone-300 (≈11:1); dark theme re-aliases on-inverse-subtle (see themes/dark)",
          "$extensions": { "com.risqbase.contrastPair": "{color.footer.background}",
            "com.risqbase.contrastLevel": "aaa",
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/link/default", "scopes": ["TEXT_FILL"] }
          }
        },
        "hover": {
          "$value": "{color.text.on-inverse}",
          "$type": "color",
          "$description": "Footer link — hover state",
          "$extensions": { "com.risqbase.contrastPair": "{color.footer.background}",
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/link/hover", "scopes": ["TEXT_FILL"] }
          }
        }
      },
      "logo": {
        "$value": "{color.brand.mark-on-inverse}",
        "$type": "color",
        "$description": "Footer logo — mark glyph + wordmark on the inverse footer surface (rev. A1: indigo-300 light / indigo-700 dark via brand.mark-on-inverse). Rendered as of the v4.4 raw-class rewire",
        "$extensions": { "com.risqbase.contrastPair": "{color.footer.background}",
          "com.risqbase.contrastLevel": "aaa",
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/logo", "scopes": ["TEXT_FILL"] }
        }
      },
      "meta": {
        "$value": "{color.neutral.stone.300}",
        "$type": "color",
        "$description": "Footer secondary text — copyright, tagline, trust badges. AAA bump (brand-mark v3 PR-A): stone-400 missed 7:1 on stone-900 → stone-300; dark theme re-aliases on-inverse-subtle (see themes/dark)",
        "$extensions": { "com.risqbase.contrastPair": "{color.footer.background}",
          "com.risqbase.contrastLevel": "aaa",
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/meta", "scopes": ["TEXT_FILL"] }
        }
      },
      "divider": {
        "$value": "{color.border.inverse}",
        "$type": "color",
        "$description": "Footer bottom-bar divider line",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/divider", "scopes": ["STROKE_COLOR"] }
        }
      }
    }
  }
}
