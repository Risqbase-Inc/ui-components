{
  "color": {
    "citation-chip": {
      "$comment": "Component-tier wrapper around the semantic `color.citation.*` chain (v4.3 §4.3). Used by CitationChip primitive in @risqbase-inc/ui-components/ai. Closes RALIA F-012 / F-025.",
      "surface":          { "$value": "{color.citation.surface-default}",  "$type": "color", "$description": "Citation chip surface — default",        "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/surface", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
      "surface-low-conf": { "$value": "{color.citation.surface-low-conf}", "$type": "color", "$description": "Citation chip surface — low-confidence", "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/surface-low-conf", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] } } },
      "border":           { "$value": "{color.citation.border-default}",   "$type": "color", "$description": "Citation chip border",                   "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/border", "scopes": ["STROKE_COLOR"] } } },
      "border-retracted": { "$value": "{color.citation.border-retracted}", "$type": "color", "$description": "Citation chip border — retracted",       "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/border-retracted", "scopes": ["STROKE_COLOR"] } } },
      "text":             { "$value": "{color.citation.text-default}",     "$type": "color", "$description": "Citation chip text",                     "$extensions": { "com.risqbase.contrastPair": "{color.citation-chip.surface}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/text", "scopes": ["TEXT_FILL"] } } },
      "text-retracted":   { "$value": "{color.citation.text-retracted}",   "$type": "color", "$description": "Citation chip text — retracted",         "$extensions": { "com.risqbase.contrastPair": "{color.citation-chip.surface-low-conf}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/text-retracted", "scopes": ["TEXT_FILL"] } } },
      "icon":             { "$value": "{color.citation.icon-default}",     "$type": "color", "$description": "Citation chip icon",                     "$extensions": { "com.risqbase.contrastPair": "{color.citation-chip.surface}", "com.risqbase.contrastLevel": "aa-large", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/icon", "scopes": ["SHAPE_FILL", "TEXT_FILL"] } } },
      "hover":            { "$value": "{color.citation.hover}",            "$type": "color", "$description": "Citation chip hover overlay",            "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/hover", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } },
      "active":           { "$value": "{color.citation.active}",           "$type": "color", "$description": "Citation chip active overlay",           "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/citation-chip/active", "scopes": ["ALL_FILLS", "SHAPE_FILL"] } } }
    }
  }
}
