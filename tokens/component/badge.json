{
  "color": {
    "badge": {
      "default": {
        "background": {
          "$value": "{color.action.primary}",
          "$type": "color",
          "$description": "Badge default background — \"Most Popular\", \"New\"",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/default/background" }
          }
        },
        "foreground": {
          "$value": "{color.text.on-action}",
          "$type": "color",
          "$description": "Badge default text colour",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/default/foreground" }
          }
        }
      },
      "highlight": {
        "background": {
          "$value": "{color.action.primary-subtle}",
          "$type": "color",
          "$description": "Badge highlight background — \"Standalone Product\"",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/highlight/background" }
          }
        },
        "foreground": {
          "$value": "{color.action.primary}",
          "$type": "color",
          "$description": "Badge highlight text colour",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/highlight/foreground" }
          }
        }
      },
      "subtle": {
        "background": {
          "$value": "{color.surface.muted}",
          "$type": "color",
          "$description": "Badge subtle background — \"Coming Soon\"",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/subtle/background" }
          }
        },
        "foreground": {
          "$value": "{color.text.subtle}",
          "$type": "color",
          "$description": "Badge subtle text colour",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/badge/subtle/foreground" }
          }
        }
      }
    }
  }
}
