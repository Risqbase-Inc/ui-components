{
  "color": {
    "gauge-component": {
      "$comment": "Component-tier wrapper around the semantic `color.gauge.*` chain (v4.3 §4.3). Used by Gauge + RiskGauge primitives in @risqbase-inc/ui-components/data-viz. Closes v4.2 audit U2.1.",
      "track":      { "$value": "{color.gauge.track}",      "$type": "color", "$description": "Gauge background track",        "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/track", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-teal":   { "$value": "{color.gauge.arc-teal}",   "$type": "color", "$description": "Gauge arc — teal (default)",    "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/arc-teal", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-indigo": { "$value": "{color.gauge.arc-indigo}", "$type": "color", "$description": "Gauge arc — indigo",             "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/arc-indigo", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "arc-stone":  { "$value": "{color.gauge.arc-stone}",  "$type": "color", "$description": "Gauge arc — stone (dual-ring)",  "$extensions": { "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/arc-stone", "scopes": ["STROKE_COLOR", "SHAPE_FILL"] } } },
      "label":      { "$value": "{color.text.default}",     "$type": "color", "$description": "Gauge centre numeric label",    "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/label", "scopes": ["TEXT_FILL"] } } },
      "caption":    { "$value": "{color.text.subtle}",      "$type": "color", "$description": "Gauge caption / unit label",    "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}", "com.risqbase.role": "component", "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/gauge-component/caption", "scopes": ["TEXT_FILL"] } } }
    }
  }
}
