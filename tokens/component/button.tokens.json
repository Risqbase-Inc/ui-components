{
  "color": {
    "button": {
      "primary": {
        "background": {
          "default": {
            "$value": "{color.action.primary}",
            "$type": "color",
            "$description": "Primary button background — default state",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/primary/background/default", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          },
          "hover": {
            "$value": "{color.action.primary-hover}",
            "$type": "color",
            "$description": "Primary button background — hover state",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/primary/background/hover", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          }
        },
        "foreground": {
          "default": {
            "$value": "{color.text.on-action}",
            "$type": "color",
            "$description": "Primary button text colour",
            "$extensions": { "com.risqbase.contrastPair": "{color.button.primary.background.default}", "com.risqbase.themeInvariant": "Pure white on action.primary in both themes — action.primary is contrast-managed per theme",
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/primary/foreground/default", "scopes": ["TEXT_FILL"] }
            }
          }
        }
      },
      "secondary": {
        "background": {
          "default": {
            "$value": "{color.surface.default}",
            "$type": "color",
            "$description": "Secondary button background — default state",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/secondary/background/default", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          },
          "hover": {
            "$value": "{color.action.primary-subtle}",
            "$type": "color",
            "$description": "Secondary button background — hover state",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/secondary/background/hover", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          }
        },
        "foreground": {
          "default": {
            "$value": "{color.action.link}",
            "$type": "color",
            "$description": "Secondary button text colour",
            "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}",
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/secondary/foreground/default", "scopes": ["TEXT_FILL"] }
            }
          }
        },
        "border": {
          "default": {
            "$value": "{color.action.primary}",
            "$type": "color",
            "$description": "Secondary button border colour",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/secondary/border/default", "scopes": ["STROKE_COLOR"] }
            }
          }
        }
      },
      "ghost": {
        "background": {
          "default": {
            "$value": "transparent",
            "$type": "color",
            "$description": "Ghost button background — default state",
            "$extensions": { "com.risqbase.themeInvariant": "Transparent in all themes by definition",
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/ghost/background/default", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          },
          "hover": {
            "$value": "{color.action.primary-subtle}",
            "$type": "color",
            "$description": "Ghost button background — hover state",
            "$extensions": {
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/ghost/background/hover", "scopes": ["ALL_FILLS", "FRAME_FILL", "SHAPE_FILL"] }
            }
          }
        },
        "foreground": {
          "default": {
            "$value": "{color.action.link}",
            "$type": "color",
            "$description": "Ghost button text colour",
            "$extensions": { "com.risqbase.contrastPair": "{color.surface.default}",
              "com.risqbase.role": "component",
              "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/ghost/foreground/default", "scopes": ["TEXT_FILL"] }
            }
          }
        }
      },
      "focus-ring": {
        "$value": "{color.border.focus}",
        "$type": "color",
        "$description": "Button focus-ring colour (all variants)",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/button/focus-ring", "scopes": ["STROKE_COLOR"] }
        }
      }
    }
  },
  "dimension": {
    "radius": {
      "button": {
        "default": {
          "$value": "{dimension.radius.lg}",
          "$type": "dimension",
          "$description": "Button border-radius — applies to all variants and sizes (12px, equals Tailwind rounded-xl). Tracked as a role token per spec §15.4 so future shape changes happen in one place.",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "dimension/radius/button/default", "scopes": ["CORNER_RADIUS"] }
          }
        }
      }
    }
  }
}
