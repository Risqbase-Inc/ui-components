{
  "color": {
    "footer": {
      "background": {
        "$value": "{color.surface.inverse}",
        "$type": "color",
        "$description": "Footer background — inverse surface",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/background" }
        }
      },
      "heading": {
        "$value": "{color.text.on-inverse}",
        "$type": "color",
        "$description": "Footer column heading text colour",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/heading" }
        }
      },
      "link": {
        "default": {
          "$value": "{color.text.on-inverse-subtle}",
          "$type": "color",
          "$description": "Footer link — default state",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/link/default" }
          }
        },
        "hover": {
          "$value": "{color.text.on-inverse}",
          "$type": "color",
          "$description": "Footer link — hover state",
          "$extensions": {
            "com.risqbase.role": "component",
            "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/link/hover" }
          }
        }
      },
      "logo": {
        "$value": "{color.action.primary}",
        "$type": "color",
        "$description": "Footer logo wordmark colour",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/logo" }
        }
      },
      "meta": {
        "$value": "{color.text.on-inverse-subtle}",
        "$type": "color",
        "$description": "Footer secondary text — copyright, tagline, trust badges",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/meta" }
        }
      },
      "divider": {
        "$value": "{color.border.inverse}",
        "$type": "color",
        "$description": "Footer bottom-bar divider line",
        "$extensions": {
          "com.risqbase.role": "component",
          "com.risqbase.figma": { "collection": "component", "mode": "light", "variable": "color/footer/divider" }
        }
      }
    }
  }
}
