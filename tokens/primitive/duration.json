{
  "duration": {
    "motion": {
      "instant": {
        "$value": "0ms",
        "$type": "duration",
        "$description": "No animation — reduced-motion fallback and never-animate states (spec §5.1, §8.5.3)",
        "$extensions": {
          "com.risqbase.role": "primitive",
          "com.risqbase.figma": { "collection": "primitive", "mode": "light", "variable": "duration/motion/instant" }
        }
      },
      "reactive": {
        "$value": "100ms",
        "$type": "duration",
        "$description": "Direct response to input — hover, focus, tooltip in, citation chip pressed state (spec §5.1, §15.3 named exemplar)",
        "$extensions": {
          "com.risqbase.role": "primitive",
          "com.risqbase.figma": { "collection": "primitive", "mode": "light", "variable": "duration/motion/reactive" }
        }
      },
      "considered": {
        "$value": "300ms",
        "$type": "duration",
        "$description": "Deliberate state change — modal open, drawer slide, panel transition, system feedback (spec §5.1)",
        "$extensions": {
          "com.risqbase.role": "primitive",
          "com.risqbase.figma": { "collection": "primitive", "mode": "light", "variable": "duration/motion/considered" }
        }
      },
      "celebratory": {
        "$value": "500ms",
        "$type": "duration",
        "$description": "Story-telling reveal — gauge fill, multi-step IRIS streaming, outcome-pattern transitions (spec §5.1, §6.5, §7.11)",
        "$extensions": {
          "com.risqbase.role": "primitive",
          "com.risqbase.figma": { "collection": "primitive", "mode": "light", "variable": "duration/motion/celebratory" }
        }
      }
    },
    "gauge": {
      "reveal": {
        "$value": "{duration.motion.celebratory}",
        "$type": "duration",
        "$description": "Gauge fill-arc reveal — alias to motion.celebratory (spec §15.6.2)",
        "$extensions": {
          "com.risqbase.role": "primitive",
          "com.risqbase.figma": { "collection": "primitive", "mode": "light", "variable": "duration/gauge/reveal" }
        }
      }
    }
  }
}
