{
  "builds": [
    {
      "src": "api/mcp.mjs",
      "use": "@vercel/node",
      "config": { "includeFiles": "public/agent/registry.json" }
    },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/mcp", "dest": "/api/mcp.mjs" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
