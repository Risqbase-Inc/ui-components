{
  "name": "@risqbase-inc/ui-components",
  "version": "2.1.0",
  "description": "Shared UI components for RisqBase products",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.mjs",
      "require": "./dist/ai/index.js"
    },
    "./data-viz": {
      "types": "./dist/data-viz/index.d.ts",
      "import": "./dist/data-viz/index.mjs",
      "require": "./dist/data-viz/index.js"
    },
    "./marketing": {
      "types": "./dist/marketing/index.d.ts",
      "import": "./dist/marketing/index.mjs",
      "require": "./dist/marketing/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.mjs",
      "require": "./dist/content/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.mjs",
      "require": "./dist/primitives/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.js"
    },
    "./tailwind.preset": "./tailwind.preset.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tailwind.preset.js",
    "tokens",
    "tools/tokens-build",
    "scripts/scanner-rules"
  ],
  "scripts": {
    "build:tokens": "node tools/tokens-build/index.js",
    "build": "npm run build:tokens && tsup",
    "docs:build": "node tools/docs-build/index.mjs build",
    "docs:check": "node tools/docs-build/index.mjs check",
    "build:storybook": "npm run build:tokens && storybook build",
    "chromatic": "chromatic --exit-once-uploaded --only-changed",
    "dev": "npm run build:tokens && tsup --watch",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:tokens": "node tools/tokens-build/lint.js",
    "verify:contrast": "node scripts/verify-contrast.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "storybook": "npm run build:tokens && storybook dev -p 6006"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0"
  },
  "peerDependenciesMeta": {
    "@visx/group": {
      "optional": true
    },
    "@visx/scale": {
      "optional": true
    },
    "@visx/shape": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/addon-viewport": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@visx/group": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "chromatic": "^16.10.0",
    "eslint": "^8.57.0",
    "next": "^16.2.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "storybook": "^8.6.18",
    "style-dictionary": "^4.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Risqbase-Inc/ui-components.git"
  },
  "author": {
    "name": "RisqBase d.o.o.",
    "email": "dev@risqbase.com",
    "url": "https://risqbase.com"
  },
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "eslintConfig": {
    "root": true,
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "env": {
      "browser": true,
      "node": true,
      "es2022": true
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "@typescript-eslint/no-explicit-any": "warn",
      "@typescript-eslint/no-empty-object-type": "warn",
      "@typescript-eslint/no-empty-function": "warn",
      "no-empty-pattern": "warn",
      "no-console": "off"
    },
    "ignorePatterns": [
      "dist/**",
      "node_modules/**",
      "src/tokens/generated.ts",
      "tools/**",
      "tailwind.preset.js"
    ]
  }
}
